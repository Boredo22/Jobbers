# Copy this file to .env and fill in real values. .env is gitignored.
# This template IS committed, so every machine knows which keys are required.

# --- Database (Step 0.3) ---
# DB_PASSWORD: any strong random string. Generate one with:
#   openssl rand -hex 24
DB_PASSWORD=
# DATABASE_URL: must embed the same password as DB_PASSWORD above.
# Format: postgres://<user>:<password>@<host>:<port>/<db>
# Port 5433 (not 5432): the Docker db publishes on host port 5433 so it won't
# collide with a native/system PostgreSQL that may already own 5432. This must
# match the published port in docker-compose.yml.
DATABASE_URL=postgres://jobber:CHANGEME@localhost:5433/jobber

# --- Notifications & scheduling (Step 1.5) ---
# NTFY_URL: your ntfy topic URL. Pick an unguessable topic name (anyone who
# knows it can read your notifications) and subscribe to it in the ntfy phone
# app. Leave blank to disable push notifications entirely.
#   e.g. https://ntfy.sh/jobber-7f3a9c2e
NTFY_URL=
# POLL_SCHEDULE_ENABLED: "true" arms the in-process cron that polls the boards
# at 08:00 and 14:00 America/New_York. Keep "false" here: this value applies to
# the tsx-watch dev process (so watch restarts don't hammer real ATS boards).
# The always-on `jobber-api` container overrides it to "true" in
# docker-compose.yml — that container is where scheduled polls actually run.
POLL_SCHEDULE_ENABLED=false

# --- AI layer (Phase 2, step 2.2) ---
# ANTHROPIC_API_KEY: your Anthropic API key (starts with sk-ant-...). Required for
# Mode A scoring; get one at https://console.anthropic.com. This key stays
# server-side — the browser never sees it. Leave blank until you run the scorer.
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY: your OpenRouter API key (starts with sk-or-...). Required
# for the "openrouter" backend; get one at https://openrouter.ai/settings/keys.
# Server-side only — the browser never sees it. Leave blank otherwise.
OPENROUTER_API_KEY=
# AI_PROVIDER: which AI backend to use (step 2.1's abstraction):
#   api        — Anthropic Messages API directly (Mode A). Needs ANTHROPIC_API_KEY.
#   cli        — shell out to the `claude` CLI (Mode B). No API key; needs Claude
#                Code installed and logged in on this machine.
#   cowork     — file-queue for a Cowork session (Mode C). No API key; a Cowork
#                session answers ai-queue/pending/ into ai-queue/done/.
#   openrouter — OpenRouter's OpenAI-compatible API (Mode D). One key, hundreds
#                of models; needs OPENROUTER_API_KEY. Model per tier is picked
#                on the AI Models page (defaults match Mode A's Haiku/Sonnet).
# Defaults to "api". Swapping providers is JUST this one line — no code changes.
AI_PROVIDER=api
# CLAUDE_BIN: (Mode B only) the `claude` executable to run. Default "claude" if
# it's on PATH; set an absolute path if not.
CLAUDE_BIN=claude
# AI_QUEUE_DIR: (Mode C only) root of the file queue CoworkProvider uses. Relative
# paths resolve from where the API process runs. Default "ai-queue" at the repo root.
AI_QUEUE_DIR=ai-queue
# SCORING_WORKER_ENABLED: "true" arms the in-process worker that drains the
# scoring queue on a timer (scores queued postings, ~every 20s). Keep "false"
# here (the dev process) so tsx-watch restarts don't quietly spend money; the
# `jobber-api` container overrides it to "true" in docker-compose.yml, and the
# manual `score:drain` script works regardless.
SCORING_WORKER_ENABLED=false
