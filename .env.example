# Copy this file to .env and fill in real values. .env is gitignored.
# This template IS committed, so every machine knows which keys are required.

# --- Database (Step 0.3) ---
# DB_PASSWORD: any strong random string. Generate one with:
#   openssl rand -hex 24
DB_PASSWORD=
# DATABASE_URL: must embed the same password as DB_PASSWORD above.
# Format: postgres://<user>:<password>@<host>:<port>/<db>
# Port 5433 (not 5432): the Docker db publishes on host port 5433 so it won't
# collide with a native/system PostgreSQL that may already own 5432. This must
# match the published port in docker-compose.yml.
DATABASE_URL=postgres://jobber:CHANGEME@localhost:5433/jobber
